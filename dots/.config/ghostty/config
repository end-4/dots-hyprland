# Load the Material You colors generated by the shell's color pipeline.
# `~/` expands to the installing user's home; `?` makes it optional so Ghostty
# starts fine before the first theme is generated.
config-file = ?~/.local/state/quickshell/user/generated/terminal/ghostty-theme.conf

# Color the GTK titlebar/headerbar from the generated theme.
# Required for window-titlebar-background/foreground (Linux/Adwaita only).
window-theme = ghostty
